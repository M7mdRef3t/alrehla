# ===========================================
# دواير — مسافتي | Environment Variables
# ===========================================
# انسخ هذا الملف إلى .env.local وأضف القيم

# -------------------------------------------
# Gemini AI (اختياري)
# -------------------------------------------
# المنصة تشتغل بدونه بمنطق احتياطي (fallback)
# احصل على المفتاح من: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=ضع_مفتاحك_هنا

# التحكم في تفعيل الذكاء الاصطناعي على الواجهة
# VITE_GEMINI_AI_ENABLED=false

# -------------------------------------------
# Analytics (اختياري)
# -------------------------------------------
# Google Analytics 4 Measurement ID
# احصل عليه من: https://analytics.google.com
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# -------------------------------------------
# ملاحظات
# -------------------------------------------
# 1. لا تشارك هذا الملف أو ترفعه على GitHub
# 2. .env.local مضاف في .gitignore
# 3. كل المتغيرات اللي تبدأ بـ VITE_ متاحة في الـ frontend
