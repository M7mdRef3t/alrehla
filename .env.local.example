# ===========================================
# دواير — مسافتي | Environment Variables
# ===========================================
# انسخ هذا الملف إلى .env.local وأضف القيم

# -------------------------------------------
# Gemini AI (اختياري)
# -------------------------------------------
# المنصة تشتغل بدونه بمنطق احتياطي (fallback)
# احصل على المفتاح من: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=ضع_مفتاحك_هنا

# التحكم في تفعيل الذكاء الاصطناعي على الواجهة
# VITE_GEMINI_AI_ENABLED=false

# -------------------------------------------
# Analytics (اختياري)
# -------------------------------------------
# Google Analytics 4 Measurement ID
# احصل عليه من: https://analytics.google.com
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Microsoft Clarity Project ID
# احصل عليه من: https://clarity.microsoft.com
# VITE_CLARITY_PROJECT_ID=vgsu1hh412
# ContentSquare Project ID (من كود uxa/<id>.js)
# VITE_CONTENTSQUARE_PROJECT_ID=8778894ca169d

# -------------------------------------------
# Sentry Monitoring (اختياري - Enterprise)
# -------------------------------------------
# Frontend DSN (Browser)
# VITE_SENTRY_DSN=https://<public_key>@oXXXX.ingest.sentry.io/<project_id>
# Backend DSN (Server/API)
# SENTRY_DSN=https://<public_key>@oXXXX.ingest.sentry.io/<project_id>
# Sampling (اختياري)
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0
# VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=0.2
# SENTRY_TRACES_SAMPLE_RATE=0.1

# -------------------------------------------
# Supabase (اختياري)
# -------------------------------------------
# لو عايز تفعّل لوحة التحكم والتتبع السحابي
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_key_here
# SUPABASE_PROJECT_REF=your_project_ref

# مفاتيح السيرفر (لوحة تحكم آمنة عبر API)
# ADMIN_API_SECRET=ضع_كود_المدير_هنا
# SUPABASE_SERVICE_ROLE_KEY=ضع_service_role_key_هنا
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@... (من Project Settings → Database → Connection string URI)
# SUPABASE_ACCESS_TOKEN=ضع_access_token_هنا
# VERCEL_TOKEN=ضع_vercel_token_هنا
# ADMIN_ALLOWED_ROLES=admin,owner,superadmin
# VITE_ADMIN_ALLOWED_ROLES=admin,owner,superadmin

# تقارير تلقائية (اختياري)
# CRON_SECRET=ضع_سر_الكرون_هنا
# PUBLIC_APP_URL=https://www.alrehla.app
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...
# RESEND_API_KEY=your_resend_key
# REPORT_EMAIL_TO=admin@alrehla.app
# REPORT_EMAIL_FROM=reports@alrehla.app

# لو بتستخدم API على دومين مختلف عن الواجهة
# VITE_ADMIN_API_BASE=https://www.alrehla.app

# -------------------------------------------
# Auth Redirect (اختياري)
# -------------------------------------------
# دومين الإنتاج النهائي: https://www.alrehla.app/
# افتراضياً الـ redirect في OAuth = نفس الدومين اللي المستخدم فاتح منه الموقع.
# لو عايز تجبره على دومين الإنتاج (مثلاً أثناء تجربة preview domains) استخدم:
# VITE_AUTH_REDIRECT_URL=https://www.alrehla.app/
# أو:
# VITE_PUBLIC_APP_URL=https://www.alrehla.app

# -------------------------------------------
# Google OAuth (مطلوب لو هتستخدم تسجيل الدخول بجوجل في Supabase)
# -------------------------------------------
# في Supabase Dashboard: Authentication → Providers → Google
# هتحتاج Client ID + Client Secret من Google Cloud OAuth (مش Project Number).
#
# GOOGLE_CLOUD_PROJECT_NUMBER=880073923613
# GOOGLE_CLOUD_PROJECT_ID=alrehla-486806
# SUPABASE_GOOGLE_CLIENT_ID=880073923613-xxxxxxxxxxxxxxxx.apps.googleusercontent.com
# SUPABASE_GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# -------------------------------------------
# بيئة الواجهة (وضع المستخدم vs وضع التطوير)
# -------------------------------------------
# user = ما يُنشر للجمهور (خرائط مفتوحة حسب الإعداد، واجهة ثابتة).
# dev  = كل الميزات والتجريب (كل الخرائط، ميزات قيد التطوير).
# لو غير معيّن: أثناء npm run dev = dev، وفي البناء للإنتاج = user.
# VITE_APP_ENV=user
# VITE_APP_ENV=dev

# رقم واتساب للتواصل (اختياري) — صيغة دولية مفضلة بدون +، مثال: 201001234567
# VITE_WHATSAPP_CONTACT_NUMBER=201023050092

# -------------------------------------------
# ملاحظات
# -------------------------------------------
# 1. لا تشارك هذا الملف أو ترفعه على GitHub
# 2. .env.local مضاف في .gitignore
# 3. كل المتغيرات اللي تبدأ بـ VITE_ متاحة في الـ frontend
