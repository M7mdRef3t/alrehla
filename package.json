{
  "name": "dawayir-masafaty-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "push:dev": "git push origin develop",
    "release": "node scripts/release-to-main.mjs",
    "start": "vite --open",
    "access:doctor": "powershell -ExecutionPolicy Bypass -File scripts/access-doctor.ps1",
    "access:bootstrap": "powershell -ExecutionPolicy Bypass -File scripts/bootstrap-access.ps1",
    "auth:google:configure": "powershell -ExecutionPolicy Bypass -File scripts/configure-supabase-google-oauth.ps1",
    "role:promote": "powershell -ExecutionPolicy Bypass -File scripts/promote-role.ps1",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run test:run",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "generate-icons": "node scripts/generate-icons.js",
    "supabase:apply-setup": "node scripts/apply-supabase-setup.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.95.3",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "lucide-react": "^0.563.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^3.7.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.2.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "framer-motion": "^12.29.2",
    "globals": "^17.2.0",
    "jsdom": "^27.4.0",
    "pg": "^8.18.0",
    "playwright": "^1.50.0",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.54.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^4.0.18"
  }
