{
  "rewrites": [
    { "source": "/analytics", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/admin/:path*", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/admin?path=overview&kind=cron-report&period=daily",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/admin?path=overview&kind=cron-report&period=weekly",
      "schedule": "0 8 * * 1"
    }
  ]
}
